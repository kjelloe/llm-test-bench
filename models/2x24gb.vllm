# Dual 24 GB GPU model set — 2× RTX 3090 / 2× RTX 4090 / similar (48 GB total, tp=2)
# Format: <short-name>  [<gguf-file>]  [<params>]  [hf:<tokenizer-repo>]
#
# This file is the standalone tp=2 counterpart to the dual-GPU section of default.vllm.
# Use it when running only dual-GPU models without the single-GPU 14B/32B entries.
#
# Context vs. single-GPU 32B (32gb.vllm):
#   tp=2 distributes KV cache across both GPUs → roughly double the KV budget.
#   qwen2.5-coder:32b: max_model_len 8192 (24 GB sg) → 65536 (tp=2, 48 GB)
#   deepseek-r1:32b:   max_model_len 8192 (24 GB sg) → 32768 (tp=2, 48 GB)
#   qwq:32b:           unusable (6 tok/s thrash on sg) → max_model_len=32768 (tp=2)
#   llama3.3:70b:      requires tp=2 minimum — does not fit on a single 24 GB GPU
#
# Run with:
#   ./run.sh --backend vllm --model-file models/2x24gb.vllm --models llama3.3:70b
#   ./compare.sh --backend vllm --model-file models/2x24gb.vllm

# ── 70B — primary tp=2 target; minimum 2× 24 GB ──────────────────────────────
# Q4_K_S (~37 GiB across 2 GPUs); proven at max_model_len=32768 on 2× RTX 3090.
# Tokenizer is gated (meta-llama) — set HF_TOKEN env var or populate hf-token.txt.
llama3.3:70b  Llama-3.3-70B-Instruct-Q4_K_S.gguf  tp=2,dtype=auto,max_model_len=32768  hf:meta-llama/Llama-3.3-70B-Instruct

# ── 32B models — tp=2 removes the single-GPU KV constraint ───────────────────
# qwen2.5-coder:32b: 10 GiB/GPU for weights → ~13 GiB KV total → max_model_len=65536
qwen2.5-coder:32b  Qwen2.5-Coder-32B-Instruct-Q4_K_M.gguf  tp=2,dtype=auto,max_model_len=65536  hf:Qwen/Qwen2.5-Coder-32B-Instruct
# deepseek-r1:32b: thinking; 10 GiB/GPU → ~13 GiB KV → max_model_len=32768 (conservative)
deepseek-r1:32b  DeepSeek-R1-Distill-Qwen-32B-Q4_K_M.gguf  tp=2,dtype=auto,max_model_len=32768,thinking  hf:deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
# qwq:32b Q5_K_M: ~11 GiB/GPU for weights → ~13 GiB KV total → max_model_len=32768
qwq:32b  QwQ-32B-Q5_K_M.gguf  tp=2,dtype=auto,max_model_len=32768,thinking  hf:Qwen/QwQ-32B
